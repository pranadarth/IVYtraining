<Window x:Class="practise2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:practise2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Border BorderBrush="Blue" BorderThickness="5" CornerRadius="100,0,100,0" Margin="30" Background="Aqua">
            <Border.Child>
                <Button Content="Hello" Height="50" Width="100"
                        Click="Button_Click"/>
            </Border.Child>
        </Border>

    </Grid>
</Window>
